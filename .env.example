# Supabase project (Project Settings -> API in the Supabase dashboard).
# EXPO_PUBLIC_ vars are bundled into the app and are safe to expose — but only
# ever put the "anon" / "public" key here. NEVER put the service_role key
# in this app; that key must stay server-side only.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
