# Supabase project (Project Settings -> API in the Supabase dashboard).
# EXPO_PUBLIC_ vars are bundled into the app and are safe to expose — but only
# ever put the "anon" / "public" key here. NEVER put the service_role key
# in this app; that key must stay server-side only.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Keep false until security-boundary.sql is applied and all Edge Functions are
# deployed. Set true in development, test every write, then apply the lock-down.
EXPO_PUBLIC_SECURE_WRITES=false

# Public Sentry project DSN. Leave empty to disable crash reporting.
EXPO_PUBLIC_SENTRY_DSN=

# EAS-only secret used during production builds to upload source maps.
# Configure this in EAS; never prefix it with EXPO_PUBLIC_ or commit its value.
# SENTRY_AUTH_TOKEN=
